{
  "name": "mbserve",
  "module": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "rm -f mbserve && bun build ./src/index.ts --compile --outfile mbserve",
    "install": "bun run build && cp mbserve ~/.local/bin"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react-dom": "^19.2.3",
    "@types/yargs": "^17.0.35"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "bun-plugin-tailwind": "^0.1.2",
    "maplibre-gl": "^5.19.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-map-gl": "^8.1.0",
    "tailwindcss": "^4.2.1",
    "yargs": "^18.0.0"
  }
}
