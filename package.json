{
  "name": "mbserve",
  "module": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "rm -f mbserve && bun build ./src/index.ts --compile --outfile mbserve",
    "install": "bun run build && cp mbserve ~/.local/bin"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/yargs": "^17.0.35"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "maplibre-gl": "^5.19.0",
    "yargs": "^18.0.0"
  }
}
